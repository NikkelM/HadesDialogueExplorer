    "CerberusBossMiscOutro01": {
      "dialogueLines": [
        {
          "cue": "Storyteller_0190",
          "speaker": "Speaker_Homer",
          "text": "Placated for the moment, terrifying Cerberus turns his attention from the Princess to the gates of Tartarus below."
        }
      ],
      "name": "CerberusBossMiscOutro01",
