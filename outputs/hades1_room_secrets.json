  "textlines": {
    "Inspect_RoomSecret01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The deepest reaches of the Underworld... the void from which all life and consciousness sprang forth during the dawn of time... the realm of Chaos. A land almost unseen even to denizens of death's kingdom."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_0535",
          "speaker": "CharProtag",
          "text": "Could you keep it down?"
        }
      ],
      "name": "Inspect_RoomSecret01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataSecrets.lua",
      "sourceLine": 235
    },
    "Inspect_RoomSecret02_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The fathomless expanses hidden in darkest corners of the Underworld stretch well past the notice of Lord Hades himself; and yet, the interfering Prince somehow discovers passage there."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_0937",
          "speaker": "CharProtag",
          "text": "It wasn't all that hard to find really."
        }
      ],
      "name": "Inspect_RoomSecret02_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataSecrets.lua",
      "sourceLine": 262
    },
    "Inspect_RoomSecret03_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Within the Underworld's quietest, most solitary, darkest abyss lies hidden evidence of the beginning of all things, of Chaos! The most ancient sculptor that has shaped this world."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_0938",
          "speaker": "CharProtag",
          "text": "I'd best take all the evidence I find."
        }
      ],
      "name": "Inspect_RoomSecret03_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
