    "Inspect_H_Intro_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "A seeming endless sprawl grows on the outskirts of the Underworld, where forlorn Shades attempt to fade away, and doleful Spirits prey upon their sorrow."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Such a dreadful place..."
        }
      ],
