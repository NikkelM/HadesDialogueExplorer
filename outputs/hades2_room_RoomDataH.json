    "Inspect_H_Boss_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Even the doleful residents of the Mourning Fields would rather languish longer there than plummet deeper into the abyss, where only the most wretched Shades reside."
        }
      ],
      "endLines": [
        {
          "condGroup": 0,
          "otherRequirements": {
            "PathFalse:GameState.ReachedTrueEnding": [
              {
                "PathFalse": [
                  "GameState",
                  "ReachedTrueEnding"
                ]
              }
            ]
          },
          "speaker": "PlayerUnit",
          "text": "Only the most wretched, serving Chronos..."
        }
      ],
      "name": "Inspect_H_Boss_02",
