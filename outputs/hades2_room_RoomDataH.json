    "Inspect_H_Boss02_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Apocalyptic hellfire for which the triple-headed monster Cerberus is known engulfs this portion of the miserable Fields; the Fear yet hanging in the air providing fuel."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Heard Asphodel would overflow like this."
        }
      ],
      "name": "Inspect_H_Boss02_02",
      "otherRequirements": {
        "Path:GameState.CompletedRunsCache": [
