    "Inspect_H_Bridge_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "A deep ravine within the Fields of Mourning spreads forth like a gash across the Underworld's heart; and even hateful spirits know to stay away."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Need to keep pushing forward, out of here..."
        }
      ],
      "name": "Inspect_H_Bridge_01",
