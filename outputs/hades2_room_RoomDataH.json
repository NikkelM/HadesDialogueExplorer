    "Inspect_H_MiniBoss01_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The dead are as innumerable as the sprigs of wheat within the Mourning Fields, but do not make for the most-satisfying sustenance for the unspeakable monstrosities therein."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "The dead have suffered enough..."
        }
      ],
