    "Inspect_H_Intro_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Amid the overgrowth near to the lowest reaches of the Underworld lurk the innumerable souls who cling to shreds of love and hope that long since ceased to be."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "It's rather bleak down here..."
        }
      ],
