    "Inspect_H_Boss_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Having quelled the fury of the fearsome triple-headed monster Cerberus, the Princess of the Dead stands poised to delve into the pits of Tartarus, where waits her lifelong foe."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "We're now so close, aren't we...?"
        }
      ],
      "name": "Inspect_H_Boss_01",
      "otherRequirements": {
        "Path:GameState.CompletedRunsCache": [
