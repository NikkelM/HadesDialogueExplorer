    "Inspect_F_Boss02_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Having revealed more of her vast experience, the Witch of the Crossroads leaves the Princess of the Dead to contemplate the limits of the knowledge she has gained."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "She must know so much..."
        }
      ],
      "name": "Inspect_F_Boss02_01",
