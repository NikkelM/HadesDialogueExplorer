    "F_Opening02_Inspect01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Near all of the near-endless pathways in suffocating Erebus lead to dead ends, and very scarce are those who can navigate them."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Took only my entire life to figure out."
        }
      ],
      "name": "F_Opening02_Inspect01",
