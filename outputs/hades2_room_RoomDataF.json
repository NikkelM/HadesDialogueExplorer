    "Inspect_F_Boss01_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Beneath the outer edge of Erebus extends a hidden region of the Underworld, known only to few, and navigable only by fewer still."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Let's hope so."
        }
      ],
