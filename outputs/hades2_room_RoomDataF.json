    "Inspect_Cocytus_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The River Cocytus winds through endless misty passageways, the wailing souls within its languid waters all denied their eternal rest."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Reminds me of home!"
        }
      ],
      "name": "Inspect_Cocytus_01",
