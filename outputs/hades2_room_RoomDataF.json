    "F_Opening03_Inspect01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Not even those with the power to enter the Crossroads at will can entirely anticipate which of its three hidden paths shall be their exit."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "I still know the way..."
        }
      ],
      "name": "F_Opening03_Inspect01",
