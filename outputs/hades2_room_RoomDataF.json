    "Inspect_F_Boss02_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Perhaps only the Moon herself can see this exceptionally hidden grove bordering Erebus, wherein practitioners of ancient sorcery may hone their craft to the fullest."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "I'm seeing it just fine."
        }
