    "F_OpeningInspect01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Within mist-shrouded, labyrinthine Erebus lie countless souls of the dead, awaiting judgment that shall never come."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "They'll be judged soon enough."
        }
      ],
      "name": "F_OpeningInspect01",
