    "Inspect_F_MiniBoss01_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The ever-restless Shades of Erebus find little peace there, save for the prickly embrace of the gnarled branches of those writhing woods."
        }
      ],
      "endLines": [
        {
