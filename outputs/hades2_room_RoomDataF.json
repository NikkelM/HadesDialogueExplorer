    "InspectArtemis01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Whilst the pale Moon's slender fingertips scarcely reach mournful Erebus, the goddess of the hunt can effortlessly navigate those woods."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "She's good, I'll give her that."
        },
        {
          "speaker": "NPC_Artemis_Field_01",
          "text": "Hm."
        }
      ],
