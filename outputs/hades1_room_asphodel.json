  "textlines": {
    "B_MiniBoss02_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The act of sorcery often ends in an untimely death and an eternity in Tartarus for careless souls, though some are able to perfect the trade, and take up permanent residence elsewhere..."
        }
      ],
      "name": "B_MiniBoss02_FirstInspect",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 914
    },
    "Inspect_B_Intro_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The once-verdant plains of Asphodel are now engulfed in scintillating flame, having been flooded by the river Phlegethon, whose hideously superheated contents could bring death swiftly even to those resistant to most heat."
        }
      ],
      "name": "Inspect_B_Intro_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 1142
    },
    "Inspect_B_Intro_02": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Within the suffocating heat of Asphodel reside the vast majority of those who lived upon the earth and died. There they persist until the end of time."
        }
      ],
      "name": "Inspect_B_Intro_02",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "Inspect_B_Intro_01_01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 1159
    },
    "Inspect_B_PreBoss_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Having traversed the flaming river Phlegethon to gain this vantage point, relentless Zagreus must now confront a foe of unimaginable savagery, who lies ahead, awaiting patiently its time to strike."
        }
      ],
      "name": "Inspect_B_PreBoss_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 387
    },
    "Inspect_B_Reprieve_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Hidden well within the limitless inferno of the river Phlegethon, somehow, a trickle of life-giving water yet remains; as though provided by the Fates themselves unto the very lucky Prince."
        }
      ],
      "name": "Inspect_B_Reprieve_01_01",
      "otherRequirements": {
        "RequiredCosmetics": [
          "AsphodelReprieve"
        ],
        "RequiredMinBiomeDepth": 3,
        "RequiredMinCompletedRuns": 0
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 1024
    },
    "Inspect_B_Shop_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The searing flame and ashes of the river Phlegethon mean nothing to the ferryman, Charon, who travels all the waters of the Underworld, bearing the dead, the damned, and all their fineries."
        }
      ],
      "name": "Inspect_B_Shop_01_01",
      "otherRequirements": {
        "RequiredMaxBiomeDepth": 5,
        "RequiredMinExits": 2
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataAsphodel.lua",
      "sourceLine": 966
    },
    "Inspect_B_Story_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "From within a humble residence in Asphodel reverberates the golden-sounding voice of lorn Eurydice, who once attempted to escape the Underworld, and failed, utterly, much like Prince Zagreus."
        }
      ],
      "name": "Inspect_B_Story_01_01",
      "nameCollision": true,
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
