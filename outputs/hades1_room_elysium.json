  "textlines": {
    "Inspect_C_Intro_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The rare, heavenly splendors of Elysium, reserved for only the most great of mortal souls, spread forth luxuriantly all about the fire-stepping Prince."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1654",
          "speaker": "CharProtag",
          "text": "Luxuriantly? Really?"
        }
      ],
      "name": "Inspect_C_Intro_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataElysium.lua",
      "sourceLine": 1351
    },
    "Inspect_C_Intro_02": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The enshrouded river of forgetfulness, Lethe, flows through the hallowed chambers of Elysium, numbing old pains and memories of the most-noble shades residing there."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1655",
          "speaker": "CharProtag",
          "text": "I'll have to give them new pains to recall."
        }
      ],
      "name": "Inspect_C_Intro_02",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "Inspect_C_Intro_01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataElysium.lua",
      "sourceLine": 1368
    },
    "Inspect_C_PreBoss_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The magnificently ominous facade of the great Elysian Stadium looms tall above the rabble-rousing Prince, as if to goad him into such a competition which he cannot hope to win."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1658",
          "speaker": "CharProtag",
          "text": "Cheers for the vote of confidence, old man."
        }
      ],
      "name": "Inspect_C_PreBoss_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataElysium.lua",
      "sourceLine": 350
    },
    "Inspect_C_Reprieve_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Within the delicately hewn constructions of Elysium exist places of peace so utterly serene and absolute as mortalkind is seldom to experience during the average short and often-painful coil."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1656",
          "speaker": "CharProtag",
          "text": "Is this really as good as it gets for mortalkind?"
        }
      ],
      "name": "Inspect_C_Reprieve_01_01",
      "otherRequirements": {
        "RequiredCosmetics": [
          "ElysiumReprieve"
        ],
        "RequiredMinBiomeDepth": 3
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataElysium.lua",
      "sourceLine": 1193
    },
    "Inspect_C_Shop_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The vast and multitudinous riches of both the surface and the Underworld are hoarded by the river-boatman, Charon, whose services are often tendered to the wealthiest within Elysium."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1657",
          "speaker": "CharProtag",
          "text": "He really gets around."
        }
      ],
      "name": "Inspect_C_Shop_01_01",
      "otherRequirements": {
        "RequiredMaxBiomeDepth": 6,
        "RequiredMinExits": 2
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataElysium.lua",
      "sourceLine": 1148
    },
    "Inspect_C_Story_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Amid Elysium's moss-covered chambers, carved of stone, stand untold numbers of eternal monuments in tribute to the greatest heroes which mortality can offer, there to honor them in life as well as death."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_1659",
          "speaker": "CharProtag",
          "text": "This place is near as gloomy as the House."
        }
      ],
      "name": "Inspect_C_Story_01_01",
      "otherRequirements": {
        "RequiredMinBiomeDepth": 3,
        "RequiredMinCompletedRuns": 1,
        "RequiredSeenRooms": [
          "C_Boss01"
        ]
      },
