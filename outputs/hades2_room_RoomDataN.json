    "Inspect_N_Hub_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "A barricade bars passage to the docks beyond the city square, leaving the denizens of the city of Ephyra confined to their ruinous environs."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "We'll get through. Even if it takes every Shade in this city."
        }
      ],
      "name": "Inspect_N_Hub_02",
