    "Inspect_N_Hub_03": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The barely-held-together city is a labyrinth of streets, some barricaded still, yet others not, each horror-filled, night after endless night."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "So many mortals lived and died in such a place..."
        }
      ],
