    "Inspect_N_Boss01_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "If once this was a pasture in which livestock grazed and roamed, now little evidence of this remains; only the mud, and half-burnt vestiges of a more-peaceful time."
        }
      ],
      "name": "Inspect_N_Boss01_02",
