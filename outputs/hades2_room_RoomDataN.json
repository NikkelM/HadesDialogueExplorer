    "Inspect_N_Hub_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The pathway to the docks is sealed shut by a phantasmal force that neither mortal nor immortal strength can budge."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "It's drawing strength from Shades..."
        }
      ],
      "name": "Inspect_N_Hub_01",
