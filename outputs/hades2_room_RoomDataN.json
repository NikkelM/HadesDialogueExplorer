    "Inspect_N_Boss02_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "On such particularly fearsome nights, the Witch of Shadows is believed to haunt this awfully putrescent field, whilst conducting her profane experiments upon the dead."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Still feel a little nauseous after that..."
        }
      ],
      "name": "Inspect_N_Boss02_02",
