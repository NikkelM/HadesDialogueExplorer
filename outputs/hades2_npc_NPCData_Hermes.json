  "textlines": {
    "HermesFieldAboutBusiness01": {
      "dialogueLines": [
        {
          "speaker": "HermesUpgrade",
          "text": "All right, M, I don't want to hold you up now that you're here, you've got important business after all. Just making sure you made it in one piece!"
        },
        {
          "speaker": "PlayerUnit",
          "text": "Still in one piece, Lord Hermes, but we'll see how long that sticks. Though who knows? Perhaps Typhon will flatten me, instead of tearing me to shreds."
        },
        {
          "speaker": "HermesUpgrade",
          "text": "Oh that is grim. Although you know what else is? This entire situation we're in. I mean, look at this place! So how about we both get out of here?"
        }
      ],
      "name": "HermesFieldAboutBusiness01",
