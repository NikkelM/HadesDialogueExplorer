    "HermesFieldGiftDecline01": {
      "dialogueLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Lord Hermes, I've a little gift for you while we're both here, if you don't mind! May this Ambrosia ensure you're always as light on your feet as can be!"
        },
        {
          "speaker": "NPC_Hermes_01",
          "text": "Really appreciate this, M, but can't accept. Wouldn't do if I showed up with a bunch of Ambrosia right now, no matter how much I or anyone might want a sip. Though, cheers!"
        }
      ],
