    "HermesFieldAboutTyphonDeath01": {
      "dialogueLines": [
        {
          "speaker": "HermesUpgrade",
          "text": "Now wait, is Typhon gone, or isn't he? Because there's been no sign of him but now Gramps has these little time-pockets, and once we go in, it's like Typhon never left!"
        },
        {
          "speaker": "PlayerUnit",
          "text": "That's more or less a way to understand it, but... how are you even here? I didn't realize Grandfather was sending others through. Do you even know how to get back?"
        },
        {
          "speaker": "HermesUpgrade",
          "text": "I run fast enough, I can get back! Gramps also left the others with the means to get us out, and we're keeping a close eye on him. I better take a look around!"
        }
      ],
