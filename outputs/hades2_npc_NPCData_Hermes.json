    "HermesFieldAboutPalace01": {
      "dialogueLines": [
        {
          "speaker": "HermesUpgrade",
          "text": "Don't fret too much about Pop's Palace up there, M! Old Typhon's big and strong and all but he can't crush what he can't see! Well, not as easily as if he could see it."
        },
        {
          "speaker": "PlayerUnit",
          "text": "That's not entirely assuring. So Lord Uncle Zeus and the rest have concealed their seat of power, leaving Typhon to direct his fury at this fortress?"
        },
        {
          "speaker": "HermesUpgrade",
          "text": "Yep, more or less! They figure that if we have to take on Typhon, and we do, this is the perfect spot! After all, it's a long way down from the summit. A quick way down, mind!"
        }
      ],
      "name": "HermesFieldAboutPalace01",
