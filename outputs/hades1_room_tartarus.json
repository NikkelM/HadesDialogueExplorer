  "textlines": {
    "A_Boss_01_Inspect01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The Erinyes; known also as the Furies, they are the trusted sentinels of Lord Hades, charged with torturing the worst of mortalkind... and ridding the Underworld of any fool enough to trespass where they do not belong."
        }
      ],
      "name": "A_Boss_01_Inspect01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "Fury2FirstAppearance",
          "Fury3FirstAppearance"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 400
    },
    "A_MiniBoss03_01_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The most violent wretches of Tartarus are sealed away even from other condemned souls; their only visitors, those fool enough to attempt escape."
        }
      ],
      "name": "A_MiniBoss03_01_FirstInspect",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 939
    },
    "A_MiniBoss04_01_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Damned, lost souls with nowhere left to turn congregate in deepest Tartarus, where they fuse together with the earth itself into odious forms which defy description."
        }
      ],
      "name": "A_MiniBoss04_01_FirstInspect",
      "otherRequirements": {
        "RequiredFalseSeenRoomsThisRun": [
          "A_MiniBoss01",
          "A_MiniBoss02",
          "A_MiniBoss03"
        ],
        "RequiredInactiveMetaUpgrade": "MinibossCountShrineUpgrade",
        "RequiredSeenEncounter": "BossHarpy1"
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 989
    },
    "A_PostBoss_01_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The path from Tartarus is finally laid bare. Far above, the heat from Phlegethon, the river of flame, is faintly felt already... even as its dangers lie in wait."
        }
      ],
      "name": "A_PostBoss_01_FirstInspect",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredFalseTextLinesThisRun": [
          "A_Boss_01_Inspect01"
        ],
        "RequiredTextLines": [
          "A_PostBoss_01_GearsInspect01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 745
    },
    "A_PostBoss_01_GearsInspect01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "None, other than those in the trusted inner circle of Lord Hades, are authorized to enter the intricate chambers connecting the vast regions of the Underworld; but the Prince decides to barge in, anyway."
        }
      ],
      "name": "A_PostBoss_01_GearsInspect01",
      "otherRequirements": {
        "RequiresLinked": true
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 766
    },
    "A_PreBoss_01_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Beyond the present chamber lies the outermost perimeter of Tartarus, promising terrifying dangers far beyond the Underworld Prince's reckoning."
        }
      ],
      "name": "A_PreBoss_01_FirstInspect",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 184
    },
    "A_Reprieve_01_FirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "A place of calm and respite, whilst perhaps unimaginable in the Underworld, occasionally is to be found, in fact."
        }
      ],
      "name": "A_Reprieve_01_FirstInspect",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 1551
    },
    "CharonFirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The infernal wares of the stygian boatman, Charon, lie sprawled about, available for sale to whomever would be willing to quench the boatman's great thirst for riches."
        }
      ],
      "name": "CharonFirstInspect",
      "nameCollision": true,
      "otherRequirements": {
        "RequiredMaxBiomeDepth": 9,
        "RequiredMinExits": 2
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 1604,
      "variants": [
        {
          "dialogueLines": [
            {
              "speaker": "Storyteller",
              "text": "The infernal wares of the stygian boatman, Charon, lie sprawled about, available for sale to whomever would be willing to quench the boatman's great thirst for riches."
            }
          ],
          "otherRequirements": {
            "RequiredMaxBiomeDepth": 9,
            "RequiredMinExits": 2
          },
          "owner": "Storyteller",
          "playOnce": true,
          "requirements": {},
          "section": "InteractTextLineSets",
          "sourceFile": "RoomDataTartarus.lua",
          "sourceLine": 1604
        },
        {
          "dialogueLines": [
            {
              "speaker": "Storyteller",
              "text": "The River Styx flows infamously through the Underworld, offering the boatman Charon expeditious travel from the realm of mortals to the lowest depths, where many of their shades reside forever."
            }
          ],
          "otherRequirements": {
            "RequiredMinRunsCleared": 1
          },
          "owner": "Storyteller",
          "playOnce": true,
          "requirements": {},
          "section": "InteractTextLineSets",
          "sourceFile": "RoomDataTartarus.lua",
          "sourceLine": 1621
        }
      ]
    },
    "Inspect_A_Story_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Within the depths of Tartarus reside the most wretched of all the shades who linger for eternity within the Underworld, whose Lord and Master is especially unkind to those attempting to cheat death."
        }
      ],
      "name": "Inspect_A_Story_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "SisyphusFirstMeeting"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 2453
    },
    "OpeningFirstInspect": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Composed of such innumerable ever-shifting interlocking chambers, the Underworld of Lord Hades all but guarantees the dead shall there remain until the end of time."
        }
      ],
      "name": "OpeningFirstInspect",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 2389
    },
    "OpeningProcGenHint": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Each time the Prince delves back into the Underworld, its ever-shifting chambers realign to frustrate his attempts to perhaps map it out."
        }
      ],
      "name": "OpeningProcGenHint",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredAnyTextLines": [
          "CharonFirstMeeting",
          "CharonFirstMeeting_Alt"
        ],
        "RequiredTextLines": [
          "OpeningFirstInspect"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 2407
    },
    "PoseidonFishQuest01": {
      "dialogueLines": [
        {
          "speaker": "NPC_Poseidon_01",
          "text": "Nephew! I'm mightily impressed with your ability to cull those rivers there of all the denizens of my domain! Your crusty father's not entitled to the bounties of the sea! But, on my limitless authority, you are! You have my Rod of Fishing... now have this!"
        }
      ],
      "name": "PoseidonFishQuest01",
      "otherRequirements": {
        "RequiredMinTotalCaughtFish": 3
      },
      "owner": "PoseidonUpgrade",
      "requirements": {
        "RequiredFalseTextLines": [
          "PoseidonFishQuest01"
        ],
        "RequiredFalseTextLinesLastRun": [
          "PoseidonWrathIntro01"
        ],
        "RequiredTextLines": [
          "PoseidonAboutFishing01",
          "PoseidonWrathIntro01"
        ]
      },
      "section": "ForcedTextLines",
      "source": "Hades 1",
      "sourceFile": "RoomDataTartarus.lua",
      "sourceLine": 1879
    },
    "PoseidonWrathIntro01": {
      "dialogueLines": [
        {
          "speaker": "NPC_Poseidon_01",
          "text": "I have to tell you something, little Hades: My relatives and I, we've been holding back one of our greatest gifts!! To see if you were worthy. And you are! My aid is yours, so call me if you need anything! Especially to smash your enemies to bits."
        }
      ],
      "name": "PoseidonWrathIntro01",
      "otherRequirements": {
        "RequiredMinCompletedRuns": 4
      },
      "owner": "PoseidonUpgrade",
      "requirements": {
        "RequiredFalseTextLines": [
          "PoseidonWrathIntro01"
        ],
