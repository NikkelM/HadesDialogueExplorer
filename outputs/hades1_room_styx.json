  "textlines": {
    "Inspect_D_Hub_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The vast Temple of Styx and its innumerable dangers now are all that separate the Underworld Prince from the land outside, which he so desperately longs to see."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2252",
          "speaker": "CharProtag",
          "text": "I've almost made it..."
        }
      ],
      "name": "Inspect_D_Hub_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredFalseTextLinesThisRun": [
          "CerberusStyxMeeting01",
          "Inspect_D_Hub_02",
          "Inspect_D_Hub_03"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 1400
    },
    "Inspect_D_Hub_02": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Not far from here, the dead begin their journey to their final resting-place down in the depths below; and so the river-boatman Charon often passes through."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2253",
          "speaker": "CharProtag",
          "text": "Generous selection of his wares."
        }
      ],
      "name": "Inspect_D_Hub_02",
      "otherRequirements": {
        "RequiredMinRunsCleared": 1
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "Inspect_D_Hub_01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 1419
    },
    "Inspect_D_Hub_03": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "The widely-feared and many-headed Cerberus, the Underworld's sentinel, presides over the entrance to this realm, devouring whole those fool enough to make attempts to flee."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2254",
          "speaker": "CharProtag",
          "text": "He loves to eat. Can you blame him?"
        }
      ],
      "name": "Inspect_D_Hub_03",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredFalseTextLinesThisRun": [
          "Inspect_D_Hub_01",
          "Inspect_D_Hub_03"
        ],
        "RequiredTextLines": [
          "CerberusBossDoorUnlock01",
          "Inspect_D_Hub_01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 1438
    },
    "Inspect_D_Hub_04": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "A crudely-hewn network of tunnels grows from one of the cold Temple's flanks, containing vicious denizens unwelcome in this realm, even in death."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2255",
          "speaker": "CharProtag",
          "text": "Satyr markings..."
        }
      ],
      "name": "Inspect_D_Hub_04",
      "otherRequirements": {
        "RequiredKills": {
          "RatThugMiniboss": 1,
          "SatyrRangedMiniboss": 1
        },
        "RequiredSeenRooms": [
          "D_Reprieve01"
        ]
      },
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredFalseTextLinesThisRun": [
          "Inspect_D_Hub_01",
          "Inspect_D_Hub_02",
          "Inspect_D_Hub_03"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 1458
    },
    "Inspect_D_Intro_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "At last the willful prince has ventured all the way up to the surface of the mortal realm, yet still he is encased within the earth itself: the gateway to the Underworld, a threshold from which there is no escape."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2251",
          "speaker": "CharProtag",
          "text": "We'll see about that."
        }
      ],
      "name": "Inspect_D_Intro_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {},
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 1080
    },
    "Inspect_D_MiniBoss_02_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Inside the filth-encrusted lairs carved into the looming edifices of the Underworld lie such terrible abominations that not even grim Lord Hades is inclined to speak of them."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2913",
          "speaker": "CharProtag",
          "text": "This gigantic vermin head deserves a lot more credit if you ask me."
        }
      ],
      "name": "Inspect_D_MiniBoss_02_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "CerberusBossDoorUnlock01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 351
    },
    "Inspect_D_Reprieve_01_01": {
      "dialogueLines": [
        {
          "speaker": "Storyteller",
          "text": "Deep within the desecrated lair of the god-defiling Satyrs lie the noisome contents of their profane rituals, so foul as to be indescribable."
        }
      ],
      "endLines": [
        {
          "cue": "ZagreusField_2256",
          "speaker": "CharProtag",
          "text": "Cerberus just loves the stuff."
        }
      ],
      "name": "Inspect_D_Reprieve_01_01",
      "otherRequirements": {},
      "owner": "Storyteller",
      "playOnce": true,
      "requirements": {
        "RequiredTextLines": [
          "CerberusBossDoorUnlock01"
        ]
      },
      "section": "InteractTextLineSets",
      "source": "Hades 1",
      "sourceFile": "RoomDataStyx.lua",
      "sourceLine": 715
    }
  }
