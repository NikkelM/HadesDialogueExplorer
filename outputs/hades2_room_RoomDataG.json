    "Inspect_G_MiniBoss01_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "That which slithers, seeps, and crawls, all of it thrives within the foul air and crushing climate near the bottom of the sea."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "The air is definitely stuffier down here..."
        }
      ],
      "name": "Inspect_G_MiniBoss01_01",
