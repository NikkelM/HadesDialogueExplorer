    "Inspect_G_MiniBoss03_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "There are such creatures born of nightmare and the sea, which float eternally toward death and decay, and so invariably find themselves exactly here."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Think I just stepped in one..."
        }
      ],
