    "Inspect_G_Boss02_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Though bolstered by colossal Charybdis, Scylla and those monstrous songstresses from the abyssal sea yet prove unable to complete their deadly act."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "In the end, a normal night for them."
        }
      ],
      "name": "Inspect_G_Boss02_01",
