    "Inspect_G_Boss01_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Where once reverberated the enthralling music of the Sirens, sheer silence now remains; yet for how long shall those immortal songstresses be stilled?"
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Doubtless only till my next attempt..."
        }
      ],
      "name": "Inspect_G_Boss01_01",
