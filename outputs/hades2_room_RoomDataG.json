    "Inspect_G_Intro_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The Underworld plunges deeper than the deepest sea; yet there are such places where the edge of one and the other meet."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "One dark abyss next to another..."
        }
