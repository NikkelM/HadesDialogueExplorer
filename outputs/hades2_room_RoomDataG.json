    "Inspect_G_MiniBoss_02_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "As surface-vermin flee from sinking vessels, so have Underworld vermin sought darker reaches of their realm, in the tumult of the times."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "It's hard to be a rodent..."
        }
      ],
      "name": "Inspect_G_MiniBoss_02_01",
