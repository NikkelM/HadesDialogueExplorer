    "Inspect_O_Devotion_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "Before the land was split, mortals would gather in great competitions for the glory of the gods; but now, the gods themselves appear to fight over the few remaining scraps."
        }
