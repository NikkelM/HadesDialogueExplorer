    "Inspect_O_Intro_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "When the armies of Chronos marched on Olympus, mighty Poseidon split the very land asunder. And so the gods contend with naval forces now..."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "Not a mistake; an opportunity."
        }
      ],
