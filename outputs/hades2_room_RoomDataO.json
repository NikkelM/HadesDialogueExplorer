    "Inspect_O_Boss01_02": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "The embodiment of Strife has vanished, yet her influence remains, as Earth and Sea alike remain embroiled in a cataclysmic conflict she is keen to endlessly perpetuate."
