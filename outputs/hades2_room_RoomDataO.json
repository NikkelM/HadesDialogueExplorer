    "Inspect_O_Boss02_01": {
      "dialogueLines": [
        {
          "speaker": "Speaker_Homer",
          "text": "A hidden secret of the ancient weapon wielded by the erratic embodiment of Strife proved not quite unpredictable enough to take the Underworld Princess off her guard."
        }
      ],
      "endLines": [
        {
          "speaker": "PlayerUnit",
          "text": "May the Rail's next bearer be more responsible."
        }
      ],
      "name": "Inspect_O_Boss02_01",
