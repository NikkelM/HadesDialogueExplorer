    "TyphonBossAltFight03": {
      "dialogueLines": [
        {
          "cue": "Chronos_1233",
          "speaker": "NPC_Chronos_01",
          "text": "It is impossible or at least utterly preposterous that you were somehow able to subdue the monster Typhon here, whilst I myself was harrying you with my various techniques! But you shall not be quite so fortunate again."
        },
        {
          "cue": "MelinoeField_3785",
          "speaker": "PlayerUnit",
          "text": "And what makes you think that? You're only here because the will of Night has brought you directly to me so I can deal with you both at once."
        },
        {
          "cue": "Chronos_1234",
          "speaker": "NPC_Chronos_01",
          "text": "Mere witchery and lies! The apparition that you see exists entirely because of my own will! To think that you could summon one such as I merely at whim!"
        }
      ],
      "name": "TyphonBossAltFight03",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 3,
      "narrativePrioritySectionSize": 4,
      "otherRequirements": {
