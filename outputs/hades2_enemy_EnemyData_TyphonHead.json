    "TyphonBossAltFight01": {
      "dialogueLines": [
        {
          "cue": "Chronos_1065",
          "speaker": "NPC_Chronos_01",
          "text": "Beg pardon the interruption, Granddaughter, but I have come to see the work of my monstrous associate upon these hallowed heights. For I have only heard the tales!"
        },
        {
          "cue": "MelinoeField_3783",
          "speaker": "PlayerUnit",
          "text": "I know the real reason that you're here on such a night. Well, I've grown accustomed to dealing with you and Typhon both. Perhaps not all at once..."
        },
        {
          "cue": "Chronos_1066",
          "speaker": "NPC_Chronos_01",
          "text": "Oh fear not, for I am but a harmless apparition presently. Harmless, inasmuch as you cannot harm me at all. Although the other way around... well, you shall see."
        }
      ],
      "name": "TyphonBossAltFight01",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 1,
      "narrativePrioritySectionSize": 4,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {
        "RequiredFalseTextLines": [
          "TyphonHeadAltFight01"
        ]
      },
      "section": "BossIntroTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 474
    },
    "TyphonBossAltFight02": {
      "dialogueLines": [
        {
          "cue": "Chronos_1231",
          "speaker": "NPC_Chronos_01",
          "text": "How can you possibly believe that you possess the wherewithal to overcome us both? For even my considerable strength pales in comparison to that of the Father of All Monsters!"
        },
        {
          "cue": "MelinoeField_3784",
          "speaker": "PlayerUnit",
          "text": "I've vanquished each of you before. I see no reason why I couldn't do it again. You'll likely just be getting in each other's way."
        },
        {
          "cue": "Chronos_1232",
          "speaker": "NPC_Chronos_01",
          "text": "I do think that Typhon shall be inconvenienced by me. But as for you, my girl... well, let us imminently see."
        }
      ],
      "name": "TyphonBossAltFight02",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 2,
      "narrativePrioritySectionSize": 4,
      "otherRequirements": {
