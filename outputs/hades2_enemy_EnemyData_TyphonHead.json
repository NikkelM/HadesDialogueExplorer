  "textlines": {
    "TyphonAltFightFinalRound01": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3790",
          "speaker": "PlayerUnit_Flashback",
          "text": "Damn you, Chronos! Once I'm through with Typhon, I am coming after you!"
        },
        {
          "cue": "Chronos_1161",
          "speaker": "NPC_Chronos_01",
          "text": "You are nothing but a pathetic child! May you always remember that, should you somehow withstand what shall imminently transpire!"
        }
      ],
      "name": "TyphonAltFightFinalRound01",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 1,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
      "section": "BossPhaseChangeTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 580
    },
    "TyphonAltFightFinalRound02": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3791",
          "speaker": "PlayerUnit_Flashback",
          "text": "Undo what you have done to me at once, or I shall purge you from existence, Titan!"
        },
        {
          "cue": "Chronos_1162",
          "speaker": "NPC_Chronos_01",
          "text": "My, how frightening. But it is most improper for a child to speak so rudely to her grandfather... so you shall have to be punished."
        }
      ],
      "name": "TyphonAltFightFinalRound02",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 2,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
      "section": "BossPhaseChangeTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 602
    },
    "TyphonAltFightFinalRound03": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3792",
          "speaker": "PlayerUnit_Flashback",
          "text": "How is this even possible? I am no longer the mere child I once was, and yet..."
        },
        {
          "cue": "Chronos_1163",
          "speaker": "NPC_Chronos_01",
          "text": "Always remember how small and frightened you once must have felt. Inside, you are still that same old wretched girl."
        }
      ],
      "name": "TyphonAltFightFinalRound03",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 3,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
      "section": "BossPhaseChangeTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 622
    },
    "TyphonAltFightFinalRound04": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3793",
          "speaker": "PlayerUnit_Flashback",
          "text": "You may chortle with that monster all you like, Titan, but the final laughter shall be mine alone!"
        },
        {
          "cue": "Chronos_1164",
          "speaker": "NPC_Chronos_01",
          "text": "There is no way to turn back Time. But I can make exceptions here and there... because I make the blasted rules!"
        }
      ],
      "name": "TyphonAltFightFinalRound04",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 4,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
      "section": "BossPhaseChangeTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 642
    },
    "TyphonAltFightFinalRound05": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3794",
          "speaker": "PlayerUnit_Flashback",
          "text": "Do you think this is funny, Titan?!"
        },
        {
          "cue": "Chronos_1165",
          "speaker": "NPC_Chronos_01",
          "text": "Let me remind you just how small and weak you truly are. We all grow older, yes, but none of us shall ever change in our entirety."
        }
      ],
      "name": "TyphonAltFightFinalRound05",
      "narrativePriorityClusterMembers": [
        "TyphonAltFightFinalRound10",
        "TyphonAltFightFinalRound07"
      ],
      "narrativePriorityOrdinal": 9,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
