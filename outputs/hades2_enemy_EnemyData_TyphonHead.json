      "sourceLine": 662
    },
    "TyphonAltFightFinalRound06": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3795",
          "speaker": "PlayerUnit_Flashback",
          "text": "You have made a grave error in judgment!"
        },
        {
          "cue": "Chronos_1166",
          "speaker": "NPC_Chronos_01",
          "text": "To think if I was but a bit more careful then I could have taken you along with all the rest of your dear family; and saved myself the trouble here!"
        }
      ],
      "name": "TyphonAltFightFinalRound06",
      "narrativePriorityClusterMembers": [],
      "narrativePriorityOrdinal": 6,
      "narrativePrioritySectionSize": 9,
      "otherRequirements": {
        "FunctionName:IsBossDifficultyShrineUpgradeActive": [
          {
            "FunctionName": "IsBossDifficultyShrineUpgradeActive"
          }
        ]
      },
      "owner": "TyphonHead",
      "playOnce": true,
      "requirements": {},
      "section": "BossPhaseChangeTextLineSets",
      "source": "Hades 2",
      "sourceFile": "EnemyData_TyphonHead.lua",
      "sourceLine": 681
    },
    "TyphonAltFightFinalRound07": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3796",
          "speaker": "PlayerUnit_Flashback",
          "text": "How you shall suffer once I break this spell!"
        },
        {
          "cue": "Chronos_1167",
          "speaker": "NPC_Chronos_01",
          "text": "Stubborn little brat! That is what you are. Look at yourself, in all your youthful frailty. This is all you ever were."
        }
      ],
      "name": "TyphonAltFightFinalRound07",
      "narrativePriorityClusterMembers": [
        "TyphonAltFightFinalRound10",
        "TyphonAltFightFinalRound05"
      ],
      "narrativePriorityOrdinal": 9,
