    "TyphonAltFightFinalRound08": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3798",
          "speaker": "PlayerUnit_Flashback",
          "text": "You'll soon learn that I'm not the little girl I once was!"
        },
        {
          "cue": "Chronos_1168",
          "speaker": "NPC_Chronos_01",
          "text": "Know your insignificance, child! You may pitter-patter all about now to your heart's content. I certainly care not!"
        }
      ],
      "name": "TyphonAltFightFinalRound08",
      "narrativePriorityClusterMembers": [],
