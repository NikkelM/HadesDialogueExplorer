    "TyphonAltFightFinalRound10": {
      "dialogueLines": [
        {
          "cue": "MelinoeField_3799",
          "speaker": "PlayerUnit_Flashback",
          "text": "Laugh all you like, you wretched fools!"
        },
        {
          "cue": "Chronos_1170",
          "speaker": "NPC_Chronos_01",
          "text": "You clearly never learned to listen to your elders, girl, so fine! I am quite finished with attempts at reasoning with you."
